# Cloudflare Pages — Cache headers
# Hashed assets (JS/CSS chunks, images, fonts) are immutable for 1 year.
# HTML is always revalidated so users get fresh deploys immediately.

/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Stable-named files (filename never changes, contents do) must revalidate.
/assets/certifications/*
  Cache-Control: public, max-age=0, must-revalidate

/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/*.html
  Cache-Control: public, max-age=0, must-revalidate
